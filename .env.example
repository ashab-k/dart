# ============================================================
# DART — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================

# GreyNoise — https://www.greynoise.io (free Community tier)
GREYNOISE_API_KEY=your_key_here

# AbuseIPDB — https://www.abuseipdb.com/api (free tier: 1000 checks/day)
ABUSEIPDB_API_KEY=your_key_here

# VirusTotal — https://www.virustotal.com/gui/my-apikey (free tier: 4 req/min)
VIRUSTOTAL_API_KEY=your_key_here

# ----- Internal service URLs (Docker network hostnames) -----
# Used by services inside Docker to talk to each other
DUMMY_SERVER_URL=http://dummy-server:3002
DART_BACKEND_URL=http://dart-backend:3001

# ----- Frontend env vars (browser-visible) -----
# These use localhost because the browser runs OUTSIDE Docker
NEXT_PUBLIC_DART_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_DUMMY_SERVER_URL=http://localhost:3002
